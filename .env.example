# Copy to .env.local for local runs, or set these as CI secrets.
# Never commit real values.

# The staging/test environment for YOUR OWN app.
BASE_URL=https://staging.yourapp.com

# Mailosaur credentials for a test inbox YOU provisioned.
MAILOSAUR_API_KEY=your_mailosaur_api_key
MAILOSAUR_SERVER_ID=your_mailosaur_server_id

# Fixed password used only for the throwaway CI test account.
TEST_USER_PASSWORD=CiTestPassw0rd!23
